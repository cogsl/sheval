@prefix sh: <http://www.w3.org/ns/shacl#> .
_:1 a sh:ValidationReport ;
	sh:conforms false ;
	sh:result _:2 , _:3 .
_:2 a sh:ValidationResult ;
	sh:focusNode <http://example.org/c> ;
	sh:sourceConstraintComponent sh:not ;
	sh:resultMessage "No message" ;
	sh:resultSeverity sh:Violation ;
	sh:sourceShape <http://example.org/S1> .
_:3 a sh:ValidationResult ;
	sh:focusNode <http://example.org/b> ;
	sh:sourceConstraintComponent sh:not ;
	sh:resultMessage "No message" ;
	sh:resultSeverity sh:Violation ;
	sh:sourceShape <http://example.org/S1> .
