@prefix sh: <http://www.w3.org/ns/shacl#> .
_:1 sh:result _:2 , _:3 ;
	a sh:ValidationReport ;
	sh:conforms false .
_:2 sh:sourceShape <http://example.org/S1> ;
	sh:focusNode <http://example.org/b> ;
	sh:resultMessage "No message" ;
	sh:sourceConstraintComponent sh:not ;
	a sh:ValidationResult ;
	sh:resultSeverity sh:Violation .
_:3 sh:sourceShape <http://example.org/S1> ;
	sh:focusNode <http://example.org/c> ;
	sh:resultMessage "No message" ;
	sh:sourceConstraintComponent sh:not ;
	a sh:ValidationResult ;
	sh:resultSeverity sh:Violation .
