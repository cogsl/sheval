PREFIX :        <http://example.org/>
PREFIX dash:    <http://datashapes.org/dash#>
PREFIX graphql: <http://datashapes.org/graphql#>
PREFIX owl:     <http://www.w3.org/2002/07/owl#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX sh:      <http://www.w3.org/ns/shacl#>
PREFIX swa:     <http://topbraid.org/swa#>
PREFIX tosh:    <http://topbraid.org/tosh#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>

[ rdf:type     sh:ValidationReport;
  sh:conforms  false;
  sh:result    [ rdf:type                      sh:ValidationResult;
                 sh:focusNode                  :a;
                 sh:resultMessage              "Value has shape _:fac4d50276ca7007a1b583a7614d642f";
                 sh:resultSeverity             sh:Violation;
                 sh:sourceConstraintComponent  sh:NotConstraintComponent;
                 sh:sourceShape                :S;
                 sh:value                      :a
               ];
  sh:result    [ rdf:type                      sh:ValidationResult;
                 sh:focusNode                  :b;
                 sh:resultMessage              "Value has shape _:fac4d50276ca7007a1b583a7614d642f";
                 sh:resultSeverity             sh:Violation;
                 sh:sourceConstraintComponent  sh:NotConstraintComponent;
                 sh:sourceShape                :S;
                 sh:value                      :b
               ];
  sh:result    [ rdf:type                      sh:ValidationResult;
                 sh:focusNode                  :c;
                 sh:resultMessage              "Value must have at least one of the following shapes: _:2cd9927898f3f5b705ff8a5df18c7558, _:772514aa7fd21fa1a1bc5f721534093a";
                 sh:resultSeverity             sh:Violation;
                 sh:sourceConstraintComponent  sh:OrConstraintComponent;
                 sh:sourceShape                :R;
                 sh:value                      :c
               ];
  sh:result    [ rdf:type                      sh:ValidationResult;
                 sh:focusNode                  :d;
                 sh:resultMessage              "Value must have at least one of the following shapes: _:2cd9927898f3f5b705ff8a5df18c7558, _:772514aa7fd21fa1a1bc5f721534093a";
                 sh:resultSeverity             sh:Violation;
                 sh:sourceConstraintComponent  sh:OrConstraintComponent;
                 sh:sourceShape                :R;
                 sh:value                      :d
               ]
] .
