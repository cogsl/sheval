PREFIX :        <http://example.org/>
PREFIX dash:    <http://datashapes.org/dash#>
PREFIX graphql: <http://datashapes.org/graphql#>
PREFIX owl:     <http://www.w3.org/2002/07/owl#>
PREFIX rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:    <http://www.w3.org/2000/01/rdf-schema#>
PREFIX sh:      <http://www.w3.org/ns/shacl#>
PREFIX swa:     <http://topbraid.org/swa#>
PREFIX tosh:    <http://topbraid.org/tosh#>
PREFIX xsd:     <http://www.w3.org/2001/XMLSchema#>

[ rdf:type     sh:ValidationReport;
  sh:conforms  false;
  sh:result    [ rdf:type                      sh:ValidationResult;
                 sh:focusNode                  :a;
                 sh:resultMessage              "Value has shape _:38e1b4dc40405cc49648df81ca6a2ec0";
                 sh:resultSeverity             sh:Violation;
                 sh:sourceConstraintComponent  sh:NotConstraintComponent;
                 sh:sourceShape                :S;
                 sh:value                      :a
               ];
  sh:result    [ rdf:type                      sh:ValidationResult;
                 sh:focusNode                  :b;
                 sh:resultMessage              "Value has shape _:38e1b4dc40405cc49648df81ca6a2ec0";
                 sh:resultSeverity             sh:Violation;
                 sh:sourceConstraintComponent  sh:NotConstraintComponent;
                 sh:sourceShape                :S;
                 sh:value                      :b
               ];
  sh:result    [ rdf:type                      sh:ValidationResult;
                 sh:focusNode                  :c;
                 sh:resultMessage              "Value must have at least one of the following shapes: _:87c906ed0ba66643c68e45e8528de28c, _:7bcae287403e6f1b8fed1199e66fe02a";
                 sh:resultSeverity             sh:Violation;
                 sh:sourceConstraintComponent  sh:OrConstraintComponent;
                 sh:sourceShape                :R;
                 sh:value                      :c
               ];
  sh:result    [ rdf:type                      sh:ValidationResult;
                 sh:focusNode                  :d;
                 sh:resultMessage              "Value must have at least one of the following shapes: _:87c906ed0ba66643c68e45e8528de28c, _:7bcae287403e6f1b8fed1199e66fe02a";
                 sh:resultSeverity             sh:Violation;
                 sh:sourceConstraintComponent  sh:OrConstraintComponent;
                 sh:sourceShape                :R;
                 sh:value                      :d
               ]
] .
