@prefix sh: <http://www.w3.org/ns/shacl#> .
_:1 a sh:ValidationReport ;
	sh:conforms false ;
	sh:result _:2 , _:3 , _:4 , _:5 .
_:2 sh:resultMessage "No message" ;
	a sh:ValidationResult ;
	sh:sourceConstraintComponent sh:not ;
	sh:resultSeverity sh:Violation ;
	sh:focusNode <http://example.org/b> ;
	sh:sourceShape <http://example.org/S> .
_:3 sh:resultMessage "No message" ;
