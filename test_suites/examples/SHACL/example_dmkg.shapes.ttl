prefix :       <http://example.org/> 
prefix sh:     <http://www.w3.org/ns/shacl#> 
prefix xsd:    <http://www.w3.org/2001/XMLSchema#>

:Person a sh:NodeShape ;
  sh:and ( 
      :Human
      [ sh:property 
          [ sh:path :knows ;
            sh:minCount 1
          ] 
      ] ) .

:Human a sh:NodeShape ;
    sh:and ( 
      :Person 
      [ sh:property 
          [ sh:path :knows ;
            sh:minCount 1
          ] 
      ]) .
