prefix :       <http://example.org/> 
prefix sh:     <http://www.w3.org/ns/shacl#> 
prefix xsd:    <http://www.w3.org/2001/XMLSchema#>

# Example 4 from https://arxiv.org/pdf/2604.20946 in SHACL
:S a sh:NodeShape ;
  sh:property [
      sh:path :p ;
      sh:qualifiedValueShape [ sh:not [ sh:node :S] ];
      sh:qualifiedMinCount 1
  ] .
