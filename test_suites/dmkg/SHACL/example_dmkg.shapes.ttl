prefix :       <http://example.org/> 
prefix sh:     <http://www.w3.org/ns/shacl#> 
prefix xsd:    <http://www.w3.org/2001/XMLSchema#>

:User a sh:NodeShape ;
  sh:and ( 
      :Person
      [ sh:property 
          [ sh:path :name ;
            sh:datatype xsd:string ;
            sh:minCount 1; 
          ]   ] 
      [ sh:property 
          [ sh:path   :knows ;
            sh:minCount 1
          ] ] ) .

:Person a sh:NodeShape ;
    sh:and ( 
      :User 
      [ sh:property 
          [ sh:path :knows ;
            sh:node :Person ;
          ] ;
      ]) .
