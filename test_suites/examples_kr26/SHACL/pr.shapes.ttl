prefix :       <http://example.org/> 
prefix sh:     <http://www.w3.org/ns/shacl#> 
prefix xsd:    <http://www.w3.org/2001/XMLSchema#>

# Positive recursion with encoding with qualified value shapes
:S a sh:NodeShape ;
   sh:or ( 
      [ sh:property 
          [ sh:path :p ;
            sh:qualifiedValueShape :S ;
            sh:qualifiedMinCount 1
          ]
      ]
      [ sh:hasValue :d ] 
   ) .
