prefix :       <http://example.org/> 
prefix sh:     <http://www.w3.org/ns/shacl#> 
prefix xsd:    <http://www.w3.org/2001/XMLSchema#>

# Consistency test 1
:S a sh:NodeShape ;
   sh:property 
          [ sh:path :p ;
            sh:not :S ;
          ] .

:S1 a sh:NodeShape ;
    sh:or ( 
        [ sh:path :p ;
          sh:qualifiedValueShape :S ;
          sh:qualifiedMinCount 1
        ]
        [ sh:hasValue :b ;
        ]
    ) .
