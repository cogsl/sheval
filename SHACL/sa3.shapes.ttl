prefix :       <http://example.org/> 
prefix sh:     <http://www.w3.org/ns/shacl#> 
prefix xsd:    <http://www.w3.org/2001/XMLSchema#>

# Separation test SA3
:S a sh:NodeShape ;
  sh:and ( 
      :S1
      [ sh:property 
          [ sh:path :p ;
            sh:minCount 1
          ] 
      ] ) .

:S1 a sh:NodeShape ;
    sh:and ( 
      :S 
      [ sh:property 
          [ sh:path :p ;
            sh:minCount 1
          ] 
      ]) .
