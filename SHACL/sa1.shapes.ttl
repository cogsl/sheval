prefix :       <http://example.org/> 
prefix sh:     <http://www.w3.org/ns/shacl#> 
prefix xsd:    <http://www.w3.org/2001/XMLSchema#>
prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
prefix schema: <http://schema.org/>

# Separation test SA1
:S a sh:NodeShape ;
   sh:property 
          [ sh:path :p ;
            sh:node :S ;
            sh:minCount 1
          ] .
