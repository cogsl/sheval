prefix :       <http://example.org/> 
prefix sh:     <http://www.w3.org/ns/shacl#> 
prefix xsd:    <http://www.w3.org/2001/XMLSchema#>

# Consistency test 2
:S a sh:NodeShape ;
   sh:property 
          [ sh:path :p ;
            sh:qualifiedValueShape :S1 ;
            sh:qualifiedMinCount 1
          ] .

:S1 a sh:NodeShape ;
    sh:not :S .
