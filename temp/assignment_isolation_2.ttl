@prefix : <http://example.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:S1 a sh:NodeShape ;
    sh:property [ sh:path :p ;
            sh:qualifiedMinCount 1 ;
            sh:qualifiedValueShape :S3 ] .

:S2 a sh:NodeShape ;
    sh:property [ sh:path :p ;
            sh:qualifiedMinCount 1 ;
            sh:qualifiedValueShape :NotS3 ] ;
    sh:targetNode :b .

:a :p :b .

:NotS3 a sh:NodeShape ;
    sh:not :S3 .

:S3 a sh:NodeShape ;
    sh:property [ sh:path :p ;
            sh:qualifiedMinCount 1 ;
            sh:qualifiedValueShape :S3 ] .

:b :p :b .

