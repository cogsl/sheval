@prefix : <http://example.org/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:S a sh:NodeShape ;
    sh:property [ sh:path :p ;
            sh:qualifiedMinCount 1 ;
            sh:qualifiedValueShape [ sh:not [ sh:node :S ] ] ] ;
    sh:targetNode :a,
        :b .

:a :p :b .

:b :p :a .

